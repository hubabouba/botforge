// Prisma schema for BotConstruct.io
// Dev uses SQLite for zero-setup local runs. For production swap `provider`
// to "postgresql" and point DATABASE_URL at your Postgres instance.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bot {
  id        String   @id @default(cuid())
  name      String
  platform  String   @default("telegram") // "telegram" | "discord"
  // Visual graph (nodes + edges) serialized as JSON string.
  graph     String   @default("{\"nodes\":[],\"edges\":[]}")
  // Bot token, AES-256-GCM encrypted. Never store plaintext.
  tokenEnc  String?
  // Runtime status: "stopped" | "running" | "error"
  status    String   @default("stopped")
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs BotLog[]
}

model BotLog {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  level     String   @default("info") // "info" | "error"
  message   String
  createdAt DateTime @default(now())

  @@index([botId, createdAt])
}

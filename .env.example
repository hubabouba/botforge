# --- Anthropic Claude API (paid-plan assistant) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Google Gemini API (free-plan assistant) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- Plans & AI routing (no Stripe needed for testing) ---
# Comma-separated email allow-lists to grant paid tiers manually:
BOTFORGE_PRO_EMAILS=""
BOTFORGE_BASIC_EMAILS=""
# Emails exempt from the daily assistant message cap (owner testing):
BOTFORGE_UNLIMITED_AI_EMAILS=""
# Force one provider regardless of plan: "gemini" | "claude" (empty = by plan)
AI_FORCE_PROVIDER=""

# --- PostHog product analytics (optional; left empty = analytics disabled) ---
# Get from https://posthog.com → Project settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Sentry error monitoring (optional; left empty = monitoring disabled) ---
# DSN from Sentry → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Needed only to upload source maps during production build / CI:
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Supabase (auth + database) ---
# From the Vercel Supabase integration, or Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Stripe (Basic/Pro subscriptions) ---
# Test-mode (sk_test_/whsec_ from a test-mode webhook) and live-mode keys are
# entirely separate in Stripe — do not mix them. In Vercel, scope live keys to
# the Production environment ONLY (never Preview), or PR previews will process
# real charges.
STRIPE_SECRET_KEY=""
# Price IDs (price_..., not prod_...) for the Basic/Pro recurring monthly Prices.
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""
# Signing secret from the webhook endpoint (Stripe Dashboard → Webhooks) — a
# separate secret per test/live endpoint.
STRIPE_WEBHOOK_SECRET=""
# Client-facing gate (build-time — requires a redeploy to change): shows real
# "Choose plan" buttons instead of "Coming soon" in the upgrade modal.
NEXT_PUBLIC_STRIPE_ENABLED="false"
# Opt-in hardening, both default off — only turn on once the matching Stripe
# Dashboard setting exists, otherwise checkout starts failing:
#  - STRIPE_REQUIRE_TOS_CONSENT: needs a Terms of Service URL set in Stripe
#    Dashboard → Public details.
#  - STRIPE_AUTOMATIC_TAX: needs Stripe Tax jurisdictions registered; collects
#    0% tax anywhere not yet registered, so enabling early is harmless.
STRIPE_REQUIRE_TOS_CONSENT="false"
STRIPE_AUTOMATIC_TAX="false"

# --- Bot hosting / "Real Run" (Fly.io) ---
# Master kill-switch. The whole hosting feature is inert until this is "true"
# (routes 503, no run controls) — lets unfinished work merge/deploy safely.
HOSTING_ENABLED="false"
# 32-byte base64 key that encrypts bot tokens at rest (AES-256-GCM). Generate
# ONCE with: openssl rand -base64 32 — and set it in Vercel Production ONLY
# (never Preview). Losing/changing it makes every stored secret undecryptable.
HOSTING_SECRETS_KEY=""
# Access itself is now a real plan check (Basic+ unlocks hosting.run) — this is
# just an override so an account testing hosting on a free plan (e.g. the
# owner's) gets Basic's numbers instead of Free's zero. Comma-separated.
HOSTING_BETA_EMAILS=""
# Fly.io Machines API (Stage 1). Token from: fly tokens create org
# FLY_APP_NAME is the Fly app that owns the per-bot Machines.
FLY_API_TOKEN=""
FLY_APP_NAME=""
# Runner image ref pushed to Fly's registry, e.g.
# registry.fly.io/botforge-bots:python. FLY_REGION is optional (defaults to the
# app's primary region).
FLY_RUNNER_IMAGE_PYTHON=""
FLY_REGION=""
# Public base URL the Machine calls back to (files/logs/exit) and links in
# emails, e.g. https://botforge-snowy.vercel.app.
BOTFORGE_PUBLIC_URL=""
# Bearer secret for the reconcile cron (Stage 2). Generate with
# openssl rand -base64 32 and set the SAME value as a GitHub repo secret so the
# scheduled workflow can authenticate. Empty = the reconcile route rejects all.
CRON_SECRET=""
# Platform-wide cap on simultaneously active Machines (blunt cost/abuse ceiling,
# independent of per-plan limits). Optional; defaults to 20, -1 = unlimited.
HOSTING_GLOBAL_MACHINE_CEILING=""

# --- Transactional email (Resend) ---
# Optional, env-gated like everything else: with these unset, all email sends
# are silent no-ops. RESEND_API_KEY from resend.com; EMAIL_FROM must be a
# verified sender, e.g. "Botforge <noreply@botforge.dev>".
RESEND_API_KEY=""
EMAIL_FROM=""
